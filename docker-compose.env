# ── Core Database & Redis Settings ─────────────────────────────────────────────
PAPERLESS_REDIS=redis://broker:6379
PAPERLESS_DBENGINE=postgresql
PAPERLESS_DBHOST=db
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=dg_secure_db_pass_123

# ── Security & URL Settings ──────────────────────────────────────────────────
# Change this secret key in production!
PAPERLESS_SECRET_KEY=dg_super_secret_key_change_me_in_production_12345
PAPERLESS_URL=http://localhost:8010

# ── Custom Branding Settings ─────────────────────────────────────────────────
PAPERLESS_APP_TITLE="DG Repo"
PAPERLESS_APP_LOGO="/usr/src/paperless/media/logo-dg.svg"

# ── Localization & OCR Settings ──────────────────────────────────────────────
PAPERLESS_TIME_ZONE=Asia/Dhaka
PAPERLESS_OCR_LANGUAGE=eng
# Allow OCR fallback to cover text rendering issues
PAPERLESS_OCR_MODE=skip_noarchive
